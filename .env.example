# Clerk Auth (get from: dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (leave as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/setup

# ─── Credential encryption ─────────────────────────────────────────────────────
# AES-256-GCM key used to encrypt user-supplied secrets (Kalshi key+PEM, GitHub
# PAT) before they're written to Clerk privateMetadata. 32 random bytes, hex.
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# OPTIONAL. Comma-separated list of PREVIOUS ENCRYPTION_KEY values used only
# as fallbacks during decrypt — so values encrypted before a rotation still
# open. Every new encrypt() uses ENCRYPTION_KEY only. Leave empty until you
# actually rotate.
#
# Rotation procedure:
#   1. Generate a new 64-hex key (command above).
#   2. Move the OLD value of ENCRYPTION_KEY into ENCRYPTION_KEY_OLD
#      (if ENCRYPTION_KEY_OLD already has entries, append with a comma:
#       ENCRYPTION_KEY_OLD=oldest,older,old).
#   3. Set ENCRYPTION_KEY to the new value.
#   4. Redeploy. Existing stored values still decrypt via fallback; every
#      re-save re-encrypts with the new key. After most users have re-saved
#      (or after a chosen grace period), drop the OLD entry.
#
# WARNING: If you change ENCRYPTION_KEY without preserving the old value
# here, every credential currently in Clerk becomes undecryptable and every
# user must re-paste from scratch. The /api/user route will surface a clear
# error in that case, not silently produce garbage signatures.
ENCRYPTION_KEY_OLD=
